# ── Ignore everything at root first ──
/*

# ── Un-ignore what we want tracked ──
!.gitignore
!.github/
!cloudfront-s3-hosting/

# ── Ignore Terraform artifacts inside cloudfront-s3-hosting ──
cloudfront-s3-hosting/.terraform/
cloudfront-s3-hosting/.terraform.lock.hcl
cloudfront-s3-hosting/*.tfstate
cloudfront-s3-hosting/*.tfstate.*
cloudfront-s3-hosting/*.tfvars